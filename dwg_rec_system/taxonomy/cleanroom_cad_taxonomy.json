{
  "version": "0.1.0",
  "domain": "cleanroom_cad",
  "description": "无尘室 CAD 图纸识别的专业分类字典与对象分类字典。code 用作系统内部稳定标识，name_cn 用作展示名称。",
  "disciplines": [
    {
      "code": "GENERAL",
      "name_cn": "通用图纸信息",
      "scope": "所有专业共用的图框、标题栏、轴网、房间、标注、图例、尺寸、引线等基础对象。",
      "subdisciplines": ["TITLE_BLOCK", "GRID_AXIS", "ROOM", "ANNOTATION", "LEGEND", "DIMENSION"]
    },
    {
      "code": "ARCH",
      "name_cn": "建筑",
      "scope": "建筑平面、墙体、门窗、楼板、洞口、建筑房间边界等。",
      "subdisciplines": ["WALL", "DOOR_WINDOW", "OPENING", "FLOOR", "BUILDING_ROOM"]
    },
    {
      "code": "INT",
      "name_cn": "内装",
      "scope": "洁净室内装、洁净板墙、吊顶、地坪、洁净门窗、房间功能与洁净等级标注。",
      "subdisciplines": ["CLEANROOM_PARTITION", "CEILING", "FLOOR_FINISH", "CLEANROOM_DOOR_WINDOW", "ROOM_FINISH"]
    },
    {
      "code": "STRUCT",
      "name_cn": "钢结构",
      "scope": "钢柱、钢梁、支撑、檩条、吊杆、埋件、节点详图等结构构件。",
      "subdisciplines": ["STEEL_COLUMN", "STEEL_BEAM", "BRACING", "PURLIN", "HANGER", "EMBEDDED_PART"]
    },
    {
      "code": "HVAC",
      "name_cn": "暖通空调",
      "scope": "送风、回风、排风、新风、洁净空调、FFU、HEPA、MAU、AHU、风管、风口、风阀等。",
      "subdisciplines": ["SUPPLY_AIR", "RETURN_AIR", "EXHAUST_AIR", "FRESH_AIR", "CLEAN_AIR", "AIR_EQUIPMENT", "AIR_TERMINAL"]
    },
    {
      "code": "FIRE",
      "name_cn": "消防",
      "scope": "水消防、喷淋、消火栓、消防管、火灾报警、烟感、温感、手报、声光报警、防排烟相关对象。",
      "subdisciplines": ["SPRINKLER", "FIRE_HYDRANT", "FIRE_PIPE", "FIRE_ALARM", "SMOKE_EXHAUST"]
    },
    {
      "code": "ELEC",
      "name_cn": "强电",
      "scope": "配电箱、配电柜、桥架、线槽、电缆、电源插座、灯具、接地、防雷等。",
      "subdisciplines": ["DISTRIBUTION", "CABLE_TRAY", "LIGHTING", "POWER_OUTLET", "GROUNDING"]
    },
    {
      "code": "ELV",
      "name_cn": "弱电",
      "scope": "网络、电话、门禁、监控、广播、综合布线、弱电桥架与终端点位。",
      "subdisciplines": ["NETWORK", "ACCESS_CONTROL", "CCTV", "PA_SYSTEM", "ELV_CABLING"]
    },
    {
      "code": "PIPING",
      "name_cn": "管道",
      "scope": "给水、排水、冷冻水、冷却水、冷凝水、工艺水、阀门、管件、管道附件等。",
      "subdisciplines": ["WATER_SUPPLY", "DRAINAGE", "CHILLED_WATER", "COOLING_WATER", "CONDENSATE", "PROCESS_WATER"]
    },
    {
      "code": "GAS",
      "name_cn": "气体",
      "scope": "特气、压缩空气、氮气、真空、排气、气体阀箱、气体柜、气体管道与检测点。",
      "subdisciplines": ["SPECIAL_GAS", "COMPRESSED_AIR", "NITROGEN", "VACUUM", "GAS_EXHAUST", "GAS_CABINET"]
    },
    {
      "code": "BMS",
      "name_cn": "自控与楼控",
      "scope": "楼控点位、传感器、执行器、控制柜、DDC、压差、温湿度、风阀执行器等。",
      "subdisciplines": ["CONTROL_PANEL", "SENSOR", "ACTUATOR", "DIFFERENTIAL_PRESSURE", "TEMPERATURE_HUMIDITY"]
    },
    {
      "code": "EQUIPMENT",
      "name_cn": "工艺与洁净设备",
      "scope": "工艺设备、洁净工作台、传递窗、风淋室、货淋室、洁净棚、设备基础与设备编号。",
      "subdisciplines": ["PROCESS_EQUIPMENT", "CLEANROOM_EQUIPMENT", "EQUIPMENT_FOUNDATION"]
    }
  ],
